generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  nombre         String
  email          String           @unique
  username       String           @unique
  passwordHash   String
  role           RoleCode
  activo         Boolean          @default(true)
  dependenciaId  Int?
  subdireccionId Int?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  dependencia    OrgDependencia?  @relation(fields: [dependenciaId], references: [id])
  subdireccion   OrgSubdireccion? @relation(fields: [subdireccionId], references: [id])
}

model Catalogo {
  id                            Int                 @id @default(autoincrement())
  dominio                       String              @default("GENERAL")
  tipo                          String
  codigo                        String
  nombre                        String
  descripcion                   String?
  activo                        Boolean             @default(true)
  actividadVersionesBaseLicitud ActividadVersion[]
  activosAmbienteInformacion    ActivoInformacion[] @relation("ActivoAmbienteInformacion")
  activosBajaProgramada         ActivoInformacion[] @relation("ActivoBajaProgramada")
  activosClasificacionInfo      ActivoInformacion[] @relation("ActivoClasificacionInfo")
  activosDatosPersonales        ActivoInformacion[] @relation("ActivoDatosPersonales")
  activosFuenteActivo           ActivoInformacion[] @relation("ActivoFuenteActivo")
  activosImpacto                ActivoInformacion[] @relation("ActivoImpacto")
  activosNivelInformacion       ActivoInformacion[] @relation("ActivoNivelInformacion")
  activosPropiedadIntelectual   ActivoInformacion[] @relation("ActivoPropiedadIntelectual")
  activosTipoInformacion        ActivoInformacion[] @relation("ActivoTipoInformacion")
  activosVisibleInternet        ActivoInformacion[] @relation("ActivoVisibleInternet")

  @@unique([tipo, codigo])
}

model ParametroSistema {
  id          Int      @id @default(autoincrement())
  modulo      String
  clave       String
  nombre      String
  descripcion String?
  valor       Json
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([modulo, clave])
}

model Rat {
  id                   Int                    @id @default(autoincrement())
  codigo               String                 @unique
  nombre               String
  descripcion          String?
  estadoGeneral        String                 @default("EN_CONSTRUCCION")
  fechaProximaRevision DateTime?
  dependenciaId        Int
  subdireccionId       Int?
  actividades          ActividadTratamiento[]
  dependencia          OrgDependencia         @relation(fields: [dependenciaId], references: [id])
  subdireccion         OrgSubdireccion?       @relation(fields: [subdireccionId], references: [id])
  versiones            RatVersion[]
}

model RatVersion {
  id            Int     @id @default(autoincrement())
  numeroVersion String
  estadoVersion String
  motivoVersion String?
  ratId         Int
  rat           Rat     @relation(fields: [ratId], references: [id])

  @@unique([ratId, numeroVersion])
}

model ActividadTratamiento {
  id            Int                @id @default(autoincrement())
  codigo        String
  nombre        String
  descripcion   String?
  ratId         Int
  estadoGeneral String             @default("EN_CONSTRUCCION")
  rat           Rat                @relation(fields: [ratId], references: [id])
  versiones     ActividadVersion[]

  @@unique([ratId, codigo])
}

model ActividadVersion {
  id                   Int                   @id @default(autoincrement())
  numeroVersion        String
  estadoVersion        String                @default("BORRADOR")
  finalidad            String?
  plazoConservacion    String?
  actividadId          Int
  baseLicitudId        Int?
  esGranEscala         Boolean               @default(false)
  fechaProximaRevision DateTime?
  motivoActualizacion  String?
  observacionLicitud   String?
  puntajeMtge          Float?
  requiereEipd         Boolean               @default(false)
  activos              ActividadActivo[]
  actividad            ActividadTratamiento  @relation(fields: [actividadId], references: [id])
  baseLicitud          Catalogo?             @relation(fields: [baseLicitudId], references: [id])
  eipd                 Eipd?
  mtgeEvaluacion       MtgeEvaluacion?
  observacionesRevision RevisionObservacion[]
  riesgos              RiesgoEvaluacion[]

  @@unique([actividadId, numeroVersion])
}

model ActivoInformacion {
  id                          Int                  @id @default(autoincrement())
  codigo                      String               @unique
  codigoActivoPadreExterno    String?
  dependenciaNombreFuente     String?
  siglaDependenciaFuente      String?
  nombre                      String
  descripcion                 String?
  version                     String?
  macroproceso                String?
  proceso                     String?
  subproceso                  String?
  usoOtrasAreasProcesos       String?
  direccionIpUrl              String?
  propietarioActivo           String?
  unidadPropietariaActivo     String?
  custodio                    String?
  areaCustodio                String?
  ubicacion                   String?
  controlesExistentes         String?
  observaciones               String?
  historico                   String?
  fechaLevantamiento          DateTime?
  confidencialidad            Int?
  integridad                  Int?
  disponibilidad              Int?
  valorActivo                 Float?
  activo                      Boolean              @default(true)
  createdAt                   DateTime             @default(now())
  updatedAt                   DateTime             @default(now()) @updatedAt
  dependenciaId               Int?
  activoPadreId               Int?
  tipoActivoId                Int?
  nivelId                     Int?
  ambienteId                  Int?
  clasificacionInfoId         Int?
  datosPersonalesId           Int?
  visibleInternetId           Int?
  fuenteActivoId              Int?
  bajaProgramadaId            Int?
  propiedadIntelectualId      Int?
  impactoId                   Int?
  dependencia                 OrgDependencia?      @relation(fields: [dependenciaId], references: [id])
  activoPadre                 ActivoInformacion?   @relation("ActivoPadreHijo", fields: [activoPadreId], references: [id])
  activosHijos                ActivoInformacion[]  @relation("ActivoPadreHijo")
  tipoActivo                  Catalogo?            @relation("ActivoTipoInformacion", fields: [tipoActivoId], references: [id])
  nivel                       Catalogo?            @relation("ActivoNivelInformacion", fields: [nivelId], references: [id])
  ambiente                    Catalogo?            @relation("ActivoAmbienteInformacion", fields: [ambienteId], references: [id])
  clasificacionInformacion    Catalogo?            @relation("ActivoClasificacionInfo", fields: [clasificacionInfoId], references: [id])
  datosPersonales             Catalogo?            @relation("ActivoDatosPersonales", fields: [datosPersonalesId], references: [id])
  visibleInternet             Catalogo?            @relation("ActivoVisibleInternet", fields: [visibleInternetId], references: [id])
  fuenteActivo                Catalogo?            @relation("ActivoFuenteActivo", fields: [fuenteActivoId], references: [id])
  bajaProgramada              Catalogo?            @relation("ActivoBajaProgramada", fields: [bajaProgramadaId], references: [id])
  propiedadIntelectual        Catalogo?            @relation("ActivoPropiedadIntelectual", fields: [propiedadIntelectualId], references: [id])
  impacto                     Catalogo?            @relation("ActivoImpacto", fields: [impactoId], references: [id])
  fuentesUsuarios             ActivoFuenteUsuario[]
  actividades                 ActividadActivo[]

  @@index([dependenciaId])
  @@index([activoPadreId])
  @@index([tipoActivoId])
  @@index([impactoId])
}

model ActivoFuenteUsuario {
  id        Int               @id @default(autoincrement())
  activoId  Int
  nombre    String
  orden     Int               @default(0)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  activo    ActivoInformacion @relation(fields: [activoId], references: [id], onDelete: Cascade)

  @@unique([activoId, nombre])
}

model ActividadActivo {
  id                 Int               @id @default(autoincrement())
  actividadVersionId Int
  activoId           Int
  actividadVersion   ActividadVersion  @relation(fields: [actividadVersionId], references: [id])
  activo             ActivoInformacion @relation(fields: [activoId], references: [id])

  @@unique([actividadVersionId, activoId])
}

model MtgeEvaluacion {
  id                  Int              @id @default(autoincrement())
  actividadVersionId  Int              @unique
  puntajeTotal        Float
  esGranEscala        Boolean
  alcanceGeografico   Int
  createdAt           DateTime         @default(now())
  duracionTratamiento Int
  observaciones       String?
  updatedAt           DateTime         @updatedAt
  variedadCategorias  Int
  versionMetodologia  String           @default("MTGE-1.0")
  volumenTitulares    Int
  actividadVersion    ActividadVersion @relation(fields: [actividadVersionId], references: [id])
}

model RiesgoEvaluacion {
  id                   Int              @id @default(autoincrement())
  actividadVersionId   Int
  nivelRiesgo          String
  controlesExistentes  String?
  createdAt            DateTime         @default(now())
  descripcion          String?
  estado               String           @default("IDENTIFICADO")
  impacto              Int
  impactoResidual      Int?
  nivelResidual        String?
  nombre               String
  probabilidad         Int
  probabilidadResidual Int?
  tratamiento          String?
  updatedAt            DateTime         @updatedAt
  actividadVersion     ActividadVersion @relation(fields: [actividadVersionId], references: [id])
}

model RevisionObservacion {
  id                    Int              @id @default(autoincrement())
  actividadVersionId    Int
  comentario            String
  campo                 String?
  autor                 String?
  fecha                 DateTime         @default(now())
  atendida              Boolean          @default(false)
  comentarioSubsanacion String?
  fechaSubsanacion      DateTime?
  subsanadoPor          String?
  actividadVersion      ActividadVersion @relation(fields: [actividadVersionId], references: [id])
}

model AuditLog {
  id             Int      @id @default(autoincrement())
  modulo         String
  entidad        String
  accion         String
  fecha          DateTime @default(now())
  actor          String   @default("system")
  actorRole      String?
  descripcion    String?
  detalleAntes   Json?
  detalleDespues Json?
  entidadId      String?
  metadata       Json?
}

model Eipd {
  id                     Int              @id @default(autoincrement())
  codigo                 String           @unique
  actividadVersionId     Int              @unique
  conclusion             String?
  createdAt              DateTime         @default(now())
  estado                 String           @default("PRE_EVALUACION")
  fechaEvaluacion        DateTime?
  medidasMitigacion      String?
  requiereConsultaPrevia Boolean          @default(false)
  resumen                String?
  updatedAt              DateTime         @updatedAt
  actividadVersion       ActividadVersion @relation(fields: [actividadVersionId], references: [id])
}

model OrgDependencia {
  id              Int                 @id @default(autoincrement())
  nombre          String
  sigla           String?
  responsable     String?
  activo          Boolean             @default(true)
  tipoProcesoId   Int
  descripcion     String?
  tipoProceso     OrgTipoProceso      @relation(fields: [tipoProcesoId], references: [id])
  subdirecciones  OrgSubdireccion[]
  rats            Rat[]
  users           User[]
  activos         ActivoInformacion[]
}

model OrgSubdireccion {
  id             Int            @id @default(autoincrement())
  nombre         String
  sigla          String?
  responsable    String?
  activo         Boolean        @default(true)
  dependenciaId  Int
  descripcion    String?
  dependencia    OrgDependencia @relation(fields: [dependenciaId], references: [id])
  rats           Rat[]
  users          User[]
}

model OrgTipoProceso {
  id           Int              @id @default(autoincrement())
  nombre       String
  descripcion  String?
  activo       Boolean          @default(true)
  dependencias OrgDependencia[]
}

enum RoleCode {
  ADMIN
  ADMIN_TECNICO
  ADMIN_FUNCIONAL
  OPERADOR
  REVISOR
  APROBADOR_FUNCIONAL
  RESPONSABLE_DEPENDENCIA
  RESPONSABLE_SUBDIRECCION
  EDITOR_OPERATIVO
  REVISOR_PROTECCION_DATOS
  REVISOR_SEGURIDAD
  AUDITOR
}
