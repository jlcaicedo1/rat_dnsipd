NODE_ENV=production
PORT=3000

# External PostgreSQL. Do not point production to the dev container.
DATABASE_URL=postgresql://rat_app:CHANGE_ME@db-host.example.internal:5432/rat_db?schema=public&connection_limit=10&pool_timeout=20

JWT_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=8h
CORS_ORIGIN=https://rat.example.internal

FRONTEND_PORT=8080
VITE_API_BASE_URL=/api
NODE_OPTIONS=--max-old-space-size=768
